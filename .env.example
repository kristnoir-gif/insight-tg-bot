# Telegram API credentials
# Get from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Bot token from @BotFather
BOT_TOKEN=your_bot_token

# Session names for Telethon clients
SESSION_NAME=user_session
BACKUP_SESSION_NAME=backup_session
THIRD_SESSION_NAME=third_session

# Прокси для избежания FloodWait (опционально)
# Формат: protocol://[user:pass@]host:port
# Примеры:
#   socks5://1.2.3.4:1080
#   socks5://username:password@1.2.3.4:1080
#   http://1.2.3.4:8080
# Рекомендуется использовать разные прокси для каждого клиента
PROXY_MAIN=
PROXY_BACKUP=
PROXY_THIRD=

# Admin Telegram user IDs
ADMIN_ID=your_telegram_id
ADMIN_IDS=your_telegram_id
